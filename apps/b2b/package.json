{
  "name": "@server/b2b",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/b2b/dist",
          "format": [
            "cjs"
          ],
          "bundle": false,
          "main": "apps/b2b/src/main.ts",
          "tsConfig": "apps/b2b/tsconfig.app.json",
          "assets": [
            "apps/b2b/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/b2b/dist/package.json",
          "{workspaceRoot}/apps/b2b/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/b2b/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@server/b2b:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@server/b2b:build:development"
          },
          "production": {
            "buildTarget": "@server/b2b:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@server/cloud": "workspace:*",
    "@server/middlewares": "workspace:*",
    "@server/protect": "workspace:*",
    "@server/security": "workspace:*",
    "@server/types": "workspace:*",
    "@server/utils": "workspace:*",
    "@server/validator": "workspace:*",
    "body-parser": "^2.2.2",
    "bwip-js": "^4.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-http-proxy": "^2.1.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ipinfo-express": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.6",
    "p-retry": "^7.1.1",
    "qrcode": "^1.5.4",
    "qs": "^6.15.0",
    "redis": "^5.11.0",
    "slugify": "^1.6.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express-http-proxy": "^1.6.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.0"
  }
}
